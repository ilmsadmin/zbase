            function setupPagination(meta) {
                const paginationElement = document.getElementById('pagination');
                paginationElement.innerHTML = '';
                
                if (meta.totalPages <= 1) {
                    return;
                }
                
                // Previous page button
                const prevLi = document.createElement('li');
                prevLi.classList.add('page-item');
                if (meta.currentPage === 1) {
                    prevLi.classList.add('disabled');
                }
                prevLi.innerHTML = `<a class="page-link" href="#" data-page="${meta.currentPage - 1}">Previous</a>`;
                paginationElement.appendChild(prevLi);
                
                // Page number buttons
                for (let i = 1; i <= meta.totalPages; i++) {
                    const pageLi = document.createElement('li');
                    pageLi.classList.add('page-item');
                    if (i === meta.currentPage) {
                        pageLi.classList.add('active');
                    }
                    pageLi.innerHTML = `<a class="page-link" href="#" data-page="${i}">${i}</a>`;
                    paginationElement.appendChild(pageLi);
                }
                
                // Next page button
                const nextLi = document.createElement('li');
                nextLi.classList.add('page-item');
                if (meta.currentPage === meta.totalPages) {
                    nextLi.classList.add('disabled');
                }
                nextLi.innerHTML = `<a class="page-link" href="#" data-page="${meta.currentPage + 1}">Next</a>`;
                paginationElement.appendChild(nextLi);
                
                // Add event listeners to pagination buttons
                document.querySelectorAll('#pagination .page-link').forEach(link => {
                    link.addEventListener('click', function(e) {
                        e.preventDefault();
                        const page = parseInt(this.getAttribute('data-page'));
                        if (!isNaN(page)) {
                            loadPosts(page);
                        }
                    });
                });
            }
            
            async function savePost() {
                try {
                    const form = document.getElementById('add-post-form');
                    const formData = new FormData(form);
                    const token = localStorage.getItem('token');
                      // Debug form data values
                    console.log('Form data values:');
                    for (const [key, value] of formData.entries()) {
                        console.log(`${key}: ${value}`);
                    }
                    
                    // Get site ID from the form
                    const siteIdValue = formData.get('siteId');
                    console.log('Raw siteId value:', siteIdValue);
                      // Create post object with validation
                    const post = {
                        title: formData.get('title'),
                        content: formData.get('content'),
                        excerpt: formData.get('excerpt'),
                        siteId: siteIdValue ? parseInt(siteIdValue) : null,
                        status: formData.get('status') || 'draft'
                    };
                    
                    // Validate required fields
                    if (!post.title) {
                        throw new Error('Post title is required');
                    }
                    
                    if (!post.siteId) {
                        throw new Error('Please select a site for this post');
                    }
                    
                    // Generate a slug from the title
                    post.slug = post.title
                        .toLowerCase()
                        .replace(/[^\w\s-]/g, '') // Remove special chars
                        .replace(/\s+/g, '-')     // Replace spaces with dashes
                        .replace(/-+/g, '-')      // Replace multiple dashes with single dash
                        .trim();
                    
                    console.log('Post object to be sent:', post);
                    console.log('Sending request to create post...');
                    
                    const response = await fetch('/posts', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'Authorization': `Bearer ${token}`
                        },
                        body: JSON.stringify(post)
                    });
                    
                    console.log('Response received:', response.status, response.statusText);
                    
                    if (!response.ok) {
                        console.error('Response status:', response.status);
                        const errorText = await response.text();
                        console.error('Response body:', errorText);
                        
                        let errorMessage = 'Failed to create post';
                        try {
                            const errorData = JSON.parse(errorText);
                            console.log('Parsed error data:', errorData);
                            
                            if (errorData && errorData.message) {
                                // Check if the error message is a string or an object/array
                                if (typeof errorData.message === 'string') {
                                    errorMessage = errorData.message;
                                } else if (Array.isArray(errorData.message)) {
                                    // Join array of error messages
                                    errorMessage = errorData.message.join('. ');
                                } else if (typeof errorData.message === 'object') {
                                    // Extract nested error messages
                                    const messages = [];
                                    for (const key in errorData.message) {
                                        if (Array.isArray(errorData.message[key])) {
                                            messages.push(`${key}: ${errorData.message[key].join(', ')}`);
                                        } else {
                                            messages.push(`${key}: ${errorData.message[key]}`);
                                        }
                                    }
                                    errorMessage = messages.join('. ');
                                }
                            } else if (errorData && errorData.error) {
                                errorMessage = errorData.error;
                            }
                        } catch (e) {
                            console.error('Error parsing JSON response:', e);
                            // If parsing fails, try to use the raw error text if it's not too long
                            if (errorText && errorText.length < 100) {
                                errorMessage = errorText;
                            }
                        }
                        
                        throw new Error(errorMessage);
                    }
                    
                    const postData = await response.json();
                    
                    // If the post is created as published, push it immediately to WordPress
                    if (post.status === 'published' && postData && postData.id) {
                        try {
                            const pushResponse = await fetch('/posts/push', {
                                method: 'POST',
                                headers: {
                                    'Content-Type': 'application/json',
                                    'Authorization': `Bearer ${token}`
                                },
                                body: JSON.stringify([postData.id])
                            });
                            
                            if (pushResponse.ok) {
                                console.log('Post pushed to WordPress successfully');
                            } else {
                                console.error('Failed to push post to WordPress:', await pushResponse.text());
                            }
                        } catch (pushError) {
                            console.error('Error pushing post to WordPress:', pushError);
                        }
                    }
                      
                    // Clear any error messages
                    clearErrorMessage('add-post-form');
                    
                    // Close modal and refresh posts
                    const modal = bootstrap.Modal.getInstance(document.getElementById('addPostModal'));
                    if (modal) {
                        modal.hide();
                    }
                    
                    // Reset form
                    form.reset();
                    
                    // Show success message
                    showSuccessMessage('Post created successfully');
                    
                    // Reload the posts list
                    loadPosts();
                } catch (error) {
                    console.error('Error saving post:', error);
                    showErrorMessage('add-post-form', 'Failed to create post: ' + error.message);
                }
            }
            

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>View Post - ZBase</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.3/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/static/css/admin.css">
    <style>
        .post-content {
            background-color: #f9f9f9;
            border-radius: 5px;
            padding: 20px;
            min-height: 300px;
        }
        .post-meta {
            font-size: 0.9rem;
            color: #6c757d;
        }
        .featured-image {
            max-height: 300px;
            object-fit: cover;
            width: 100%;
        }
        .badge-section {
            margin-bottom: 15px;
        }
    </style>
</head>
<body>
    <!-- Top Navbar -->
    <%- include('../partials/navbar', {activePage: 'posts'}) %>

    <div class="container-fluid">
        <!-- Main content -->
        <main class="px-md-4 py-4">
            <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pb-2 mb-3 border-bottom">
                <h1 class="h2" id="post-title">Post Details</h1>
                <div class="btn-toolbar mb-2 mb-md-0">
                    <a href="/admin/posts" class="btn btn-sm btn-outline-secondary me-2">
                        <i class="bi bi-arrow-left"></i> Back to Posts
                    </a>
                    <button type="button" class="btn btn-sm btn-primary edit-post-btn">
                        <i class="bi bi-pencil"></i> Edit Post
                    </button>
                </div>
            </div>

            <div class="row mb-4">
                <div class="col-md-8">
                    <!-- Post main information -->
                    <div class="card mb-4 shadow-sm">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <h5 class="mb-0">Content</h5>
                            <span class="badge rounded-pill" id="post-status-badge">Status</span>
                        </div>
                        <div class="card-body">
                            <div id="post-content" class="post-content"></div>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <!-- Post meta information -->
                    <div class="card mb-4 shadow-sm">
                        <div class="card-header">
                            <h5 class="mb-0">Information</h5>
                        </div>
                        <div class="card-body">
                            <div class="mb-3">
                                <h6>Post Details</h6>
                                <ul class="list-group list-group-flush">
                                    <li class="list-group-item d-flex justify-content-between align-items-center">
                                        ID
                                        <span id="post-id" class="badge bg-primary rounded-pill">-</span>
                                    </li>
                                    <li class="list-group-item d-flex justify-content-between align-items-center">
                                        Slug
                                        <span id="post-slug" class="text-secondary">-</span>
                                    </li>
                                    <li class="list-group-item d-flex justify-content-between align-items-center">
                                        Site
                                        <span id="post-site" class="text-secondary">-</span>
                                    </li>
                                    <li class="list-group-item d-flex justify-content-between align-items-center">
                                        Created
                                        <span id="post-created" class="text-secondary">-</span>
                                    </li>
                                    <li class="list-group-item d-flex justify-content-between align-items-center">
                                        Updated
                                        <span id="post-updated" class="text-secondary">-</span>
                                    </li>
                                    <li class="list-group-item d-flex justify-content-between align-items-center">
                                        WordPress ID
                                        <span id="post-wp-id" class="badge bg-info rounded-pill">-</span>
                                    </li>
                                </ul>
                            </div>
                            
                            <div class="mb-3">
                                <h6>Categories</h6>
                                <div id="post-categories" class="badge-section">
                                    <!-- Will be populated by JavaScript -->
                                </div>
                            </div>
                            
                            <div class="mb-3">
                                <h6>Tags</h6>
                                <div id="post-tags" class="badge-section">
                                    <!-- Will be populated by JavaScript -->
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Post excerpt and meta -->
                    <div class="card mb-4 shadow-sm">
                        <div class="card-header">
                            <h5 class="mb-0">Excerpt & Meta</h5>
                        </div>
                        <div class="card-body">
                            <div class="mb-3">
                                <h6>Excerpt</h6>
                                <p id="post-excerpt" class="text-secondary">-</p>
                            </div>
                            
                            <div class="mb-3">
                                <h6>Meta Information</h6>
                                <ul class="list-group list-group-flush">
                                    <li class="list-group-item d-flex justify-content-between align-items-center">
                                        Meta Title
                                        <span id="post-meta-title" class="text-secondary">-</span>
                                    </li>
                                    <li class="list-group-item d-flex justify-content-between align-items-center">
                                        Meta Description
                                        <span id="post-meta-description" class="text-secondary">-</span>
                                    </li>
                                </ul>
                            </div>

                            <div id="featured-image-container" class="mb-3 d-none">
                                <h6>Featured Image</h6>
                                <img id="post-featured-image" src="" alt="Featured Image" class="img-fluid featured-image">
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {            // Check if user is logged in and has admin role
            checkAuth();
            
            // Get post ID from controller context
            const postId = '<%= postId %>';
            
            if (!postId || isNaN(parseInt(postId))) {
                window.location.href = '/admin/posts';
                return;
            }
            
            // Fetch post data
            fetchPostDetails(postId);
              // Edit button event listener
            document.querySelector('.edit-post-btn').addEventListener('click', function() {
                // Open edit modal on admin/posts page
                sessionStorage.setItem('editPostId', postId);
                window.location.href = '/admin/posts';
            });
        });          function fetchPostDetails(postId) {
            const token = localStorage.getItem('token');
            console.log('Using token for API request:', token ? 'Token present' : 'No token');
            
            fetch(`/posts/${postId}`, {
                method: 'GET',
                headers: {
                    'Content-Type': 'application/json',
                    'Authorization': `Bearer ${token}`
                }
            })
            .then(response => {
                if (!response.ok) {
                    throw new Error('Failed to fetch post details');
                }
                return response.json();
            })
            .then(post => {
                displayPostDetails(post);
            })            .catch(error => {
                console.error('Error fetching post details:', error);
                // Show more detailed error message
                const errorMessage = `Error fetching post details: ${error.message}. Please try again later.`;
                alert(errorMessage);
                // Add error message to the page
                document.getElementById('post-title').innerText = 'Error Loading Post';
                document.getElementById('post-content').innerHTML = `
                    <div class="alert alert-danger">
                        <h4>Error Loading Post</h4>
                        <p>${errorMessage}</p>
                        <p>Please check the browser console for more details.</p>
                    </div>
                `;
            });
        }
        
        function displayPostDetails(post) {
            // Set basic post information
            document.getElementById('post-title').innerText = post.title;
            document.getElementById('post-id').innerText = post.id;
            document.getElementById('post-slug').innerText = post.slug;
            
            // Set post content
            document.getElementById('post-content').innerHTML = post.content;
            
            // Set post excerpt
            document.getElementById('post-excerpt').innerText = post.excerpt || 'No excerpt provided';
            
            // Set post site
            document.getElementById('post-site').innerText = post.site ? post.site.name : 'N/A';
            
            // Set post dates
            const createdDate = new Date(post.created_at || post.createdAt).toLocaleString();
            const updatedDate = new Date(post.updated_at || post.updatedAt).toLocaleString();
            document.getElementById('post-created').innerText = createdDate;
            document.getElementById('post-updated').innerText = updatedDate;
            
            // Set WordPress ID
            const wpIdElement = document.getElementById('post-wp-id');
            if (post.wp_post_id) {
                wpIdElement.innerText = post.wp_post_id;
            } else {
                wpIdElement.innerText = 'N/A';
                wpIdElement.classList.remove('bg-info');
                wpIdElement.classList.add('bg-secondary');
            }
            
            // Set post status
            const statusBadge = document.getElementById('post-status-badge');
            statusBadge.innerText = post.status || 'draft';
            if (post.status === 'published') {
                statusBadge.classList.add('bg-success');
            } else {
                statusBadge.classList.add('bg-secondary');
            }
            
            // Set categories
            const categoriesContainer = document.getElementById('post-categories');
            if (post.categories && post.categories.length > 0) {
                post.categories.forEach(category => {
                    const badge = document.createElement('span');
                    badge.classList.add('badge', 'bg-primary', 'me-1', 'mb-1');
                    badge.innerText = category;
                    categoriesContainer.appendChild(badge);
                });
            } else {
                categoriesContainer.innerText = 'No categories';
            }
            
            // Set tags
            const tagsContainer = document.getElementById('post-tags');
            if (post.tags && post.tags.length > 0) {
                post.tags.forEach(tag => {
                    const badge = document.createElement('span');
                    badge.classList.add('badge', 'bg-secondary', 'me-1', 'mb-1');
                    badge.innerText = tag;
                    tagsContainer.appendChild(badge);
                });
            } else {
                tagsContainer.innerText = 'No tags';
            }
            
            // Set meta information
            if (post.meta) {
                document.getElementById('post-meta-title').innerText = post.meta.meta_title || '-';
                document.getElementById('post-meta-description').innerText = post.meta.meta_description || '-';
                
                // Set featured image if available
                if (post.meta.featured_image) {
                    const imageContainer = document.getElementById('featured-image-container');
                    const featuredImage = document.getElementById('post-featured-image');
                    featuredImage.src = post.meta.featured_image;
                    imageContainer.classList.remove('d-none');
                }
            }
        }
          // Auth check function
        function checkAuth() {
            const token = localStorage.getItem('token');
            const userData = localStorage.getItem('user');
            
            console.log('Authentication check - Token exists:', !!token);
            console.log('Authentication check - User data exists:', !!userData);
            
            if (!token || !userData) {
                alert('You need to log in to view this page');
                window.location.href = '/login';
                return;
            }
            
            try {
                const user = JSON.parse(userData);
                console.log('Authentication check - User roles:', user.roles || 'No roles found');
                
                const validRoles = ['admin', 'editor'];
                const hasValidRole = user.roles && user.roles.some(role => validRoles.includes(role));
                
                if (!hasValidRole) {
                    alert('You do not have permission to access this page');
                    window.location.href = '/dashboard';
                }
            } catch (error) {
                console.error('Error parsing user data:', error);
                alert('Session data is invalid. Please log in again.');
                window.location.href = '/login';
            }
        }
    </script>
</body>
</html>
